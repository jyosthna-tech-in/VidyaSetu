generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id               String            @id @default(uuid())
  name             String?
  email            String            @unique
  password         String?
  class            String?        
  image            String?
  role             UserRole          @default(STUDENT)
  isEmailVerified  Boolean           @default(false)
  firstTime        Boolean           @default(true)
  emailVerifiedAt  DateTime?
  streakCount      Int               @default(0)
  lastActiveDate   DateTime?
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  deletedAt        DateTime?
  aigenerationLogs AIGenerationLog[]
  accounts         Account[]
  notes            Note[]
  quizzes          Quiz[]
  quizSessions     QuizSession[]
  refreshTokens    RefreshToken[]
  stats            UserStats?

  @@index([email])
}
model Account {
  id                String       @id @default(uuid())
  userId            String
  provider          AuthProvider
  providerAccountId String
  accessToken       String?
  refreshToken      String?
  tokenExpiresAt    DateTime?
  createdAt         DateTime     @default(now())
  user              User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model RefreshToken {
  id        String   @id @default(uuid())
  userId    String
  token     String   @unique
  userAgent String?
  ipAddress String?
  expiresAt DateTime
  revoked   Boolean  @default(false)
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model AcademicClass {
  id       String    @id @default(uuid())
  level    Int       @unique
  subjects Subject[]
}

model Subject {
  id              String        @id @default(uuid())
  name            String
  academicClassId String
  chapters        Chapter[]
  academicClass   AcademicClass @relation(fields: [academicClassId], references: [id], onDelete: Cascade)

  @@index([academicClassId])
}

model Chapter {
  id            String  @id @default(uuid())
  title         String
  order         Int
  subjectId     String
  subject       Subject @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  pdf           String?
  content       String?
  contentFormat String?
  contentSource String?
  topics        Topic[]

  @@index([subjectId])
}

model Topic {
  id        String     @id @default(uuid())
  title     String
  order     Int
  content   String?
  chapterId String
  questions Question[]
  chapter   Chapter    @relation(fields: [chapterId], references: [id], onDelete: Cascade)

  @@index([chapterId])
}

model Question {
  id           String             @id @default(uuid())
  topicId      String?
  type         QuestionType
  difficulty   Difficulty
  questionText String
  explanation  String?
  createdAt    DateTime           @default(now())
  options      Option[]
  topic        Topic?             @relation(fields: [topicId], references: [id])
  responses    QuestionResponse[]

  @@index([topicId])
  @@index([difficulty])
}

model Option {
  id         String   @id @default(uuid())
  questionId String
  label      String
  value      String
  isCorrect  Boolean  @default(false)
  question   Question @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@index([questionId])
}

model Quiz {
  id            String        @id @default(uuid())
  userId        String
  mode          QuizMode
  source        QuizSource
  chapterId     String?
  topicId       String?
  noteId        String?
  questionCount Int
  createdAt     DateTime      @default(now())
  note          Note?         @relation(fields: [noteId], references: [id])
  user          User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  sessions      QuizSession[]

  @@index([userId])
  @@index([chapterId])
  @@index([topicId])
}

model QuizSession {
  id             String             @id @default(uuid())
  userId         String
  quizId         String
  totalQuestions Int
  correctCount   Int
  accuracy       Float
  timeTaken      Int
  startedAt      DateTime           @default(now())
  completedAt    DateTime?
  responses      QuestionResponse[]
  quiz           Quiz               @relation(fields: [quizId], references: [id], onDelete: Cascade)
  user           User               @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([quizId])
}

model QuestionResponse {
  id               String                @id @default(uuid())
  sessionId        String
  questionId       String
  selectedOptionId String?
  subjectiveAnswer String?
  isCorrect        Boolean?
  score            Float?
  timeTaken        Int
  question         Question              @relation(fields: [questionId], references: [id], onDelete: Cascade)
  session          QuizSession           @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  evaluation       SubjectiveEvaluation?

  @@index([sessionId])
  @@index([questionId])
}

model SubjectiveEvaluation {
  id             String           @id @default(uuid())
  responseId     String           @unique
  feedback       String
  idealAnswer    String?
  keywordsMissed String?
  status         EvaluationStatus @default(PENDING)
  createdAt      DateTime         @default(now())
  response       QuestionResponse @relation(fields: [responseId], references: [id], onDelete: Cascade)
}

model AIGenerationLog {
  id               String   @id @default(uuid())
  userId           String
  quizId           String?
  modelUsed        String
  promptTokens     Int?
  completionTokens Int?
  costEstimate     Float?
  status           String
  createdAt        DateTime @default(now())
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Note {
  id            String    @id @default(uuid())
  userId        String
  title         String
  content       String?
  fileUrl       String?
  extractedText String?
  version       Int       @default(1)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  deletedAt     DateTime?
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  quizzes       Quiz[]

  @@index([userId])
}

model UserStats {
  id              String    @id @default(uuid())
  userId          String    @unique
  totalSessions   Int       @default(0)
  totalQuestions  Int       @default(0)
  totalCorrect    Int       @default(0)
  overallAccuracy Float     @default(0)
  easyAccuracy    Float     @default(0)
  mediumAccuracy  Float     @default(0)
  hardAccuracy    Float     @default(0)
  currentStreak   Int       @default(0)
  longestStreak   Int       @default(0)
  lastActivityDate DateTime?
  updatedAt       DateTime  @updatedAt
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)
}

enum UserRole {
  STUDENT
  ADMIN
}

enum AuthProvider {
  CREDENTIALS
  GOOGLE
}

enum QuizMode {
  PRACTICE
  TEST
  REVISION
}

enum QuizSource {
  CHAPTER
  TOPIC
  NOTE
  AI
  CUSTOM
}

enum QuestionType {
  MCQ
  SUBJECTIVE
}

enum Difficulty {
  EASY
  MEDIUM
  HARD
}

enum EvaluationStatus {
  PENDING
  COMPLETED
  FAILED
}
